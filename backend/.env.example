# App Configuration
NODE_ENV=development
PORT=5001
APP_NAME=College ERP
APP_URL=http://localhost:5000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=eiilm_college
DB_USER=root
DB_PASSWORD=root

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=college-erp-bucket

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@collegeerp.com

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif,mp4,mov

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Seed Data (optional)
SEED_ADMIN_EMAIL=admin@eiilm.edu
SEED_ADMIN_PASSWORD=Admin@123
SEED_STUDENT_EMAIL=student@eiilm.edu
SEED_STUDENT_PASSWORD=Student@123
