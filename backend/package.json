{
  "name": "college-erp-backend",
  "version": "1.0.0",
  "description": "Enterprise-grade college management platform backend",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "seed": "ts-node -r tsconfig-paths/register src/scripts/seed.ts",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:migrate:undo:all && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "college",
    "erp",
    "cms",
    "express",
    "node",
    "typescript"
  ],
  "author": "Your Organization",
  "license": "MIT",
  "dependencies": {
    "aws-sdk": "2.1450.0",
    "axios": "1.6.2",
    "bcryptjs": "2.4.3",
    "cloudinary": "1.40.0",
    "cors": "2.8.5",
    "date-fns": "2.30.0",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-rate-limit": "7.0.0",
    "geoip-lite": "^2.0.3",
    "helmet": "7.0.0",
    "joi": "17.11.0",
    "jsonwebtoken": "9.0.2",
    "jwt-decode": "4.0.0",
    "mammoth": "^1.12.0",
    "multer": "1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "3.6.5",
    "nodemailer": "6.9.7",
    "openai": "^6.44.0",
    "pdf-parse": "^1.1.1",
    "redis": "4.6.10",
    "sequelize": "6.35.2",
    "uuid": "9.0.1",
    "winston": "3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "sequelize-cli": "^6.6.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
